    public var table as Dictionary = {
        ' ' => [0.550, []],
        '-' => [0.500, [[[0.120,0.500],[0.880,0.500]]]],
        '/' => [0.500, [[[0.850,0.000],[0.150,1.000]]]],
        '0' => [0.760, [[[0.320,0.000],[0.680,0.000],[0.950,0.180],[1.000,0.500],[0.950,0.820],[0.680,1.000],[0.320,1.000],[0.050,0.820],[0.000,0.500],[0.050,0.180],[0.320,0.000]]]],
