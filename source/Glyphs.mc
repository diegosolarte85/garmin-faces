        'G' => [0.740, [[[1.000,0.180],[0.720,0.000],[0.280,0.000],[0.000,0.220],[0.000,0.780],[0.280,1.000],[0.720,1.000],[1.000,0.800],[1.000,0.520],[0.550,0.520]]]],
        'H' => [0.700, [[[0.000,0.000],[0.000,1.000]],[[1.000,0.000],[1.000,1.000]],[[0.000,0.500],[1.000,0.500]]]],
        'I' => [0.300, [[[0.500,0.000],[0.500,1.000]]]],
