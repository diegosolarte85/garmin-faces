<?xml version="1.0" encoding="UTF-8"?>
<drawables>
    <bitmap id="LauncherIcon" filename="launcher_icon.png"/>
    <!-- Pre-baked dial art (454x454). packingFormat="png" keeps full color
         depth (no palette dithering) so the smooth waves/gradients stay clean
         on-device. Always-on is drawn as sparse vector, so no dim bitmaps. -->
    <bitmap id="DialBlack" filename="dial_black_ceramic.png" packingFormat="png"/>
    <bitmap id="DialDawn" filename="dial_dawn.png" packingFormat="png"/>
    <!-- Digital/Sport style background: waves + trident + wordmark only. -->
    <bitmap id="DialDigitalBlack" filename="dial_digital_black_ceramic.png" packingFormat="png"/>
    <bitmap id="DialDigitalDawn" filename="dial_digital_dawn.png" packingFormat="png"/>
</drawables>
